# MeshCue Forge Configuration
# Copy to .env and fill in values

# === AI Model Endpoints (optional — offline mode used when not set) ===
ZOO_CAD_API_KEY=           # Zoo (ex-KittyCAD) API key for text-to-CAD
ZOO_CAD_ENDPOINT=          # Default: https://api.zoo.dev
LLAMA_MESH_ENDPOINT=       # LLaMA-Mesh server URL for AI enclosure generation
HUNYUAN3D_ENDPOINT=        # Hunyuan3D server URL for 3D model generation
COSMOS_ENDPOINT=           # NVIDIA Cosmos server URL for video generation

# === Local Tool Paths (optional — features disabled when not found) ===
PYTHON_PATH=python3        # Python 3.x interpreter path
KICAD_PATH=                # KiCad CLI path (e.g., /usr/bin/kicad-cli)
OPENSCAD_PATH=             # OpenSCAD path (optional, for CLI rendering)

# === Backend Selection (optional — sensible defaults used) ===
FORGE_ENCLOSURE_BACKEND=openscad    # openscad | cadquery | zoo-cad | llama-mesh
FORGE_PCB_BACKEND=skidl             # skidl | kicad
FORGE_VIZ_BACKEND=hunyuan3d         # hunyuan3d | cosmos | llama-mesh

# === Feature Flags ===
FORGE_ENABLE_GPU=false     # Enable GPU-accelerated backends

# === MeshCue Connect — Patient Communication ===
MESHCUE_AT_API_KEY=          # Africa's Talking API key
MESHCUE_AT_USERNAME=         # Africa's Talking username (use "sandbox" for testing)
MESHCUE_AT_SHORTCODE=        # SMS short code (e.g., 5555)
MESHCUE_WA_TOKEN=            # WhatsApp Business API token
MESHCUE_WA_PHONE_ID=         # WhatsApp phone number ID
MESHCUE_VOICE_PROVIDER=      # "africastalking" or "twilio"
MESHCUE_TWILIO_SID=          # Twilio account SID (if using Twilio)
MESHCUE_TWILIO_TOKEN=        # Twilio auth token
MESHCUE_TWILIO_PHONE=        # Twilio phone number
MESHCUE_DEFAULT_CHANNEL=sms  # Default: sms
MESHCUE_DEFAULT_LANGUAGE=en  # Default: en
MESHCUE_ESCALATION_PHONE=    # Fallback phone for critical alerts
