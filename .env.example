# MeshCue Forge Configuration
# Copy to .env and fill in values

# === AI Model Endpoints (optional — offline mode used when not set) ===
ZOO_CAD_API_KEY=           # Zoo (ex-KittyCAD) API key for text-to-CAD
ZOO_CAD_ENDPOINT=          # Default: https://api.zoo.dev
LLAMA_MESH_ENDPOINT=       # LLaMA-Mesh server URL for AI enclosure generation
HUNYUAN3D_ENDPOINT=        # Hunyuan3D server URL for 3D model generation
COSMOS_ENDPOINT=           # NVIDIA Cosmos server URL for video generation

# === Local Tool Paths (optional — features disabled when not found) ===
PYTHON_PATH=python3        # Python 3.x interpreter path
KICAD_PATH=                # KiCad CLI path (e.g., /usr/bin/kicad-cli)
OPENSCAD_PATH=             # OpenSCAD path (optional, for CLI rendering)

# === Backend Selection (optional — sensible defaults used) ===
FORGE_ENCLOSURE_BACKEND=openscad    # openscad | cadquery | zoo-cad | llama-mesh
FORGE_PCB_BACKEND=skidl             # skidl | kicad
FORGE_VIZ_BACKEND=hunyuan3d         # hunyuan3d | cosmos | llama-mesh

# === Feature Flags ===
FORGE_ENABLE_GPU=false     # Enable GPU-accelerated backends

# === MeshCue Connect — Platform Configuration ===
# Note: Individual clinics configure their own API keys via MCP tools.
# These are PLATFORM-LEVEL defaults used only when no clinic config exists.
MESHCUE_DEFAULT_CHANNEL=sms       # Platform default delivery channel
MESHCUE_DEFAULT_LANGUAGE=en       # Platform default language
MESHCUE_MAX_RETRIES=3             # Delivery retries before escalation
MESHCUE_ESCALATION_PHONE=         # Platform-level emergency fallback

# === Infrastructure ===
MESHCUE_DB_PATH=./data/meshcue.db  # SQLite database path (Connect + RAM stores)
MESHCUE_HEALTH_PORT=8080           # Health/readiness probe port (Docker/k8s)
MESHCUE_WEBHOOK_PORT=8081          # Incoming SMS/WhatsApp/USSD/Voice callback port
MESHCUE_CORS_ORIGIN=               # Allowed CORS origin for webhook (empty = no CORS headers)

# === WhatsApp (Meta Cloud API) ===
MESHCUE_WA_VERIFY_TOKEN=meshcue-verify  # Meta webhook verification token

# === Mesh Network ===
MESHCUE_MESH_ENDPOINT=ws://localhost:9871  # Mesh P2P network WebSocket endpoint
MESHCUE_MESH_SECRET=                       # HMAC-SHA256 shared secret for mesh auth
