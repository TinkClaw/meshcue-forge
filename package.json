{
  "name": "@meshcue/forge",
  "version": "0.1.0",
  "description": "MeshCue Forge — the hardware compiler. Describe it, build it, print it.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "meshcue-forge": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "node --test dist/**/*.test.js",
    "test:watch": "node --test --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "hardware",
    "mcp",
    "circuit",
    "firmware",
    "3d-printing",
    "enclosure",
    "esp32",
    "arduino",
    "kicad",
    "openscad"
  ],
  "author": "TinkClaw",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "better-sqlite3": "^12.8.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.0.0"
  }
}
