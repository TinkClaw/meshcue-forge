// Embossed label
module label() {
  translate([37.5, 0.2, 15])
    rotate([90, 0, 0])
      linear_extrude(height=0.6)
        text("MeshCue", size=5, halign="center", valign="center", font="Liberation Sans:style=Bold");
}

// ─── Snap-fit Clips ────────────────────────────
clip_w = 8;
clip_h = 2;
clip_depth = 1.5;

module clip() {
  hull() {
    cube([clip_w, clip_depth, clip_h]);
    translate([clip_w/2, clip_depth, clip_h]) sphere(r=0.5, $fn=16);
  }
}

module clips_base() {
  // Left and right clips
  translate([-clip_depth, case_height/2 - clip_w/2, split_z - clip_h])
    rotate([0, 0, -90]) clip();
  translate([case_width, case_height/2 - clip_w/2, split_z - clip_h])
    rotate([0, 0, 90]) clip();
}

module clips_lid() {
  // Matching slots
  translate([-0.1, case_height/2 - clip_w/2 - tolerance, split_z - clip_h - tolerance])
    cube([clip_depth + 0.2, clip_w + tolerance*2, clip_h + tolerance*2]);
  translate([case_width - clip_depth - 0.1, case_height/2 - clip_w/2 - tolerance, split_z - clip_h - tolerance])
    cube([clip_depth + 0.2, clip_w + tolerance*2, clip_h + tolerance*2]);
}

// ─── Assembly ──────────────────────────────────
module base() {
  difference() {
    intersection() {
      shell();
      cube([case_width, case_height, split_z]);
    }
    cutouts();
    vents();
  }
  mount_posts();
  clips_base();
  label();
}

module lid() {
  difference() {
    intersection() {
      shell();
      translate([0, 0, split_z])
        cube([case_width, case_height, case_depth - split_z]);
    }
    cutouts();
    clips_lid();
  }
}

